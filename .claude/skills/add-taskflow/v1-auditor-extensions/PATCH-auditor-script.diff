+// Reassign round-trip: same task / same user reassigns A→B then B→A within
+// 60 min. Signal class: bot picked the wrong assignee (magnetism /
+// ambiguity), user reverted. Uses JSON1 extraction on the details payload
+// — the reassign engine writes {from_assignee, to_assignee, ...}.
+const reassignRoundTripStmts = {
+  1: tfDb.prepare(
+    `SELECT a.task_id, a.by, a.at AS first_at, a.details AS first_details,
+            b.at AS second_at, b.details AS second_details${
+              hasTaskHistoryTriggerTurnId
+                ? ', b.trigger_turn_id AS second_trigger_turn_id'
+                : ', NULL AS second_trigger_turn_id'
+            }
+     FROM task_history a
+     JOIN task_history b ON a.task_id = b.task_id
+       AND a.by = b.by
+       AND a.board_id = b.board_id
+       AND b.at > a.at
+       AND (julianday(b.at) - julianday(a.at)) * 86400 <= 3600
+     WHERE a.board_id IN (?) AND a.at >= ? AND a.at <= ?
+       AND a.action = 'reassigned' AND b.action = 'reassigned'
+       AND a.by IS NOT NULL
+       AND json_extract(a.details, '$.from_assignee') = json_extract(b.details, '$.to_assignee')
+       AND json_extract(a.details, '$.to_assignee')   = json_extract(b.details, '$.from_assignee')
+     ORDER BY b.at ASC`
+  ),
+  2: tfDb.prepare(
+    `SELECT a.task_id, a.by, a.at AS first_at, a.details AS first_details,
+            b.at AS second_at, b.details AS second_details${
+              hasTaskHistoryTriggerTurnId
+                ? ', b.trigger_turn_id AS second_trigger_turn_id'
+                : ', NULL AS second_trigger_turn_id'
+            }
+     FROM task_history a
+     JOIN task_history b ON a.task_id = b.task_id
+       AND a.by = b.by
+       AND a.board_id = b.board_id
+       AND b.at > a.at
+       AND (julianday(b.at) - julianday(a.at)) * 86400 <= 3600
+     WHERE a.board_id IN (?, ?) AND a.at >= ? AND a.at <= ?
+       AND a.action = 'reassigned' AND b.action = 'reassigned'
+       AND a.by IS NOT NULL
+       AND json_extract(a.details, '$.from_assignee') = json_extract(b.details, '$.to_assignee')
+       AND json_extract(a.details, '$.to_assignee')   = json_extract(b.details, '$.from_assignee')
+     ORDER BY b.at ASC`
+  ),
+};
